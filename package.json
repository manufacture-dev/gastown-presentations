{
  "name": "gastown-dilitrust-presentation",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "slidev --open",
    "build": "slidev build",
    "export": "slidev export --format pdf --output gastown-dilitrust-presentation.pdf",
    "export:pptx": "slidev export --format pptx --output gastown-dilitrust-presentation.pptx",
    "format": "slidev format slides.md"
  },
  "dependencies": {
    "@slidev/cli": "^52.2.0",
    "slidev-theme-the-unnamed": "git+https://github.com/jlrigau/slidev-theme-the-unnamed.git#fix-shiki-browser-editor"
  },
  "devDependencies": {
    "playwright-chromium": "^1.60.0",
    "qrcode": "^1.5.4"
  },
  "overrides": {
    "dompurify": "^3.4.3"
  }
}
